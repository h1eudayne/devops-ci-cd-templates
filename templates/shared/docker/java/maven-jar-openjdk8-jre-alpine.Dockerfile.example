## build stage ##
FROM maven:3.5.3-jdk-8-alpine AS build

WORKDIR /app
COPY . .
RUN mvn install -DskipTests=true

## run stage ##
FROM alpine:3.19

RUN adduser -D appuser \
    && apk add --no-cache openjdk8-jre-base

WORKDIR /run
# Thay ten JAR ben duoi bang artifact Maven thuc te cua project.
COPY --from=build /app/target/your-app-0.0.1-SNAPSHOT.jar /run/app.jar

RUN chown -R appuser:appuser /run

USER appuser

EXPOSE 8080

ENTRYPOINT ["/usr/lib/jvm/java-1.8-openjdk/bin/java", "-jar", "/run/app.jar"]
