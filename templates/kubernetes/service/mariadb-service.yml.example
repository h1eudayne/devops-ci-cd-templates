# =============================================================================
# Template: Kubernetes Service NodePort (MariaDB Service)
# -----------------------------------------------------------------------------
# Lưu ý quan trọng:
#   - Service này có tên mariadb-service, khớp với serviceName cấu hình trong
#     StatefulSet MariaDB.
#   - Kiểu NodePort cho phép bạn truy cập cơ sở dữ liệu MariaDB từ bên ngoài
#     cụm Kubernetes thông qua địa chỉ IP của bất kỳ Node nào và cổng vật lý
#     31306 (nằm trong dải cổng NodePort mặc định 30000-32767).
#
# Hướng dẫn sử dụng:
#   1. Sao chép file này và đổi tên bỏ đuôi .example:
#        cp mariadb-service.yml.example mariadb-service.yml
#   2. Cấu hình đúng namespace (mặc định: ecommerce).
#   3. Áp dụng cấu hình:
#        kubectl apply -f mariadb-service.yml
#   4. Kiểm tra trạng thái:
#        kubectl get svc -n ecommerce
#        kubectl get endpoints mariadb-service -n ecommerce
#   5. Kết nối thử từ máy khách bên ngoài (sử dụng DBeaver, Navicat hoặc mysql-client):
#        mysql -h <NODE_IP> -P 31306 -u root -p
# =============================================================================

apiVersion: v1
kind: Service
metadata:
  name: mariadb-service
  namespace: ecommerce
spec:
  selector:
    app: mariadb # Khớp với nhãn (label) app: mariadb của Pod MariaDB
  type: NodePort
  ports:
    - port: 3306      # Cổng nội bộ của Service trong cluster
      targetPort: 3306 # Cổng thực tế của container MariaDB
      nodePort: 31306  # Cổng vật lý trên mỗi node để truy cập từ ngoài
